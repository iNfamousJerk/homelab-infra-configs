# ──────────────────────────────────────────────
# Pipeline Environment Variables
# Copy this file to .env and fill in all values
# ──────────────────────────────────────────────

# ─── Runtime Identity ─────────────────────────
COMPOSE_PROJECT_NAME=data-pipeline
PUID=1000
PGID=1000
TZ=America/New_York
UMASK=002
RESTART_POLICY=unless-stopped

# ─── Storage Paths ────────────────────────────
STAGING_PATH=/mnt/data/pipeline/staging
CURATED_PATH=/mnt/data/pipeline/curated
CATALOG_PATH=/mnt/data/pipeline/catalog
TRANSCODE_CACHE=/mnt/data/pipeline/transcode

# ─── Networking (Docker Bridge Subnets) ───────
EGRESS_SUBNET=172.20.0.0/24
EGRESS_GATEWAY=172.20.0.1
SERVICE_SUBNET=172.20.1.0/24
SERVICE_GATEWAY=172.20.1.1
INGRESS_SUBNET=172.20.2.0/24
INGRESS_GATEWAY=172.20.2.1

# ─── Secure Egress Gateway (VPN) ──────────────
# Set VPN_SERVICE_PROVIDER to empty to skip the VPN gateway
VPN_SERVICE_PROVIDER=
VPN_TYPE=openvpn
VPN_USER=your_vpn_username
VPN_PASSWORD=your_vpn_password
# VPN_SERVER_REGIONS=US
# VPN_SERVER_CITIES=US-CA
# VPN_PORT_FORWARDING=off
# VPN_PORT_FORWARDING_PROVIDER=
VPN_FIREWALL=on
VPN_FIREWALL_DEBUG=off
VPN_HEALTH_INITIAL=30s
TUN_DEVICE=/dev/net/tun

# ─── Ingress Controller ───────────────────────
HTTP_PORT=80
HTTPS_PORT=443
INGRESS_ADMIN_PORT=81

# ─── Credential Vault ─────────────────────────
VAULT_SIGNUPS_ALLOWED=false
VAULT_DOMAIN=https://vault.internal.lan
VAULT_WEBSOCKET=true
VAULT_ADMIN_TOKEN=change_this_to_a_secure_random_token
VAULT_PORT=8082

# ─── Service Ports ────────────────────────────
P2P_UI_PORT=8080
P2P_PEER_PORT=6881
INDEX_ROUTER_PORT=9696
INGESTION_ENGINE_PORT=7878
INGESTION_ENGINE_EPISODIC_PORT=8989
INGESTION_ENGINE_AUDIO_PORT=8686
ENRICHMENT_PORT=6767
CDN_PORT=8096
ORCHESTRATOR_PORT=5055
CIRCUIT_BREAKER_PORT=8191

# ─── DNS ──────────────────────────────────────
DNS_PRIMARY=1.1.1.1
